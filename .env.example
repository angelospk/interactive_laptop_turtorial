# Environment Variables — copy to .env and fill in real values
# ΑΝΤΙΓΡΑΨΕ ΣΕ .env και συμπλήρωσε τις πραγματικές τιμές

## Development (Local) / Τοπική ανάπτυξη
# No environment variables needed — uses local.db automatically.
# Δεν χρειάζονται μεταβλητές — χρησιμοποιείται αυτόματα το local.db.

## Production (Vercel + Turso)
# Create a Turso database at https://turso.tech and set these in
# your Vercel project settings (or in .env for a local prod test):

TURSO_DATABASE_URL=libsql://<your-database-name>.turso.io
TURSO_AUTH_TOKEN=<your-turso-auth-token>

# Usually set automatically by Vercel
NODE_ENV=production

## Session signing
# HMAC secret for signing session cookies. REQUIRED in production (min 16 chars).
# Generate a strong one: `openssl rand -base64 32`
# Μυστικό HMAC για υπογραφή session cookies. ΥΠΟΧΡΕΩΤΙΚΟ σε production (≥16 χαρακτ.).
SESSION_SECRET=<run: openssl rand -base64 32>

## Admin Panel
# Pick a strong password. NEVER ship the default to production.
# Διάλεξε δυνατό password. ΜΗΝ αφήσεις το default σε production.
ADMIN_PASSWORD=<change-me>

# Base URL for markdown course content.
# Local/dev (before repo is public): /content
# Production (after repo is public): https://cdn.jsdelivr.net/gh/<user>/<repo>@main/content
PUBLIC_CONTENT_BASE_URL=/content
